# ============================================
# OmniSync VPS Stack - Configuración
# ============================================

# PostgreSQL
DB_NAME=omnisync
DB_USER=omnisync
DB_PASSWORD=CAMBIAR_contraseña_segura

# JWT Auth
JWT_SECRET=CAMBIAR_clave_secreta_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# MikroTik
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=443
MIKROTIK_USER=admin
MIKROTIK_PASS=tu_password_mikrotik

# FreeRADIUS
RADIUS_SECRET=testing123
RADIUS_DB_PASSWORD=CAMBIAR_radius_password
MYSQL_ROOT_PASSWORD=CAMBIAR_mysql_root

# PHPNuxBill
NUXBILL_DB_PASSWORD=CAMBIAR_nuxbill_password
NUXBILL_DB_PASS=CAMBIAR_nuxbill_password
NUXBILL_APP_URL=http://TU_IP/nuxbill
NUXBILL_FORCE_SYNC_SETTINGS=0
# Portal cautivo: 'default' = fábrica NuxBill, 'omnisync' = tema OmniSync con QR
NUXBILL_PORTAL=default

# VPN / WireGuard
# Si la detección automática de IP falla, configure manualmente:
VPS_PUBLIC_IP=

# Opcionales
TZ=America/Bogota
